# NDPA launch env template

# Required: clean metadata Postgres/Supabase pooler URL.
DATABASE_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-us-west-2.pooler.supabase.com:6543/postgres"

# Hosted API URL. For single-project Vercel deploys, use https://YOUR-DOMAIN/api.
NDPA_PUBLIC_API_BASE_URL="https://YOUR-DOMAIN/api"
NDPA_CORS_ORIGINS="https://YOUR-DOMAIN,https://www.YOUR-DOMAIN"

# Required for console admin key minting.
NDPA_ADMIN_TOKEN="replace-with-long-random-secret"

# Raw memory storage. Hosted NDPA uses Cloudflare R2.
# Env names use S3 because R2 exposes an S3-compatible API.
NDPA_HYDRATION_BACKEND="s3"
NDPA_S3_ENDPOINT="https://ACCOUNT_ID.r2.cloudflarestorage.com"
NDPA_S3_BUCKET="ndpa-raw"
NDPA_S3_REGION="auto"
NDPA_S3_ACCESS_KEY_ID="replace-me"
NDPA_S3_SECRET_ACCESS_KEY="replace-me"

# Optional hosted Reasoning. If omitted, customers can use BYOK with X-OpenAI-API-Key.
OPENAI_API_KEY=""
NDPA_REASONING_MODEL="gpt-5-mini"
NDPA_REASONING_CONTEXT_CHARS="12000"

# Optional billing handoff. Console checkout reports not configured if empty.
NDPA_STRIPE_PAYMENT_LINK=""

# Optional tuning.
DB_POOL_MIN="1"
DB_POOL_MAX="5"
NDPA_AUTH_CACHE_TTL_SEC="45"
NDPA_PREDICTION_CACHE_TTL_SEC="20"
