# Required: Supabase Postgres connection string
# Get it from: Supabase Dashboard -> Project -> Settings -> Database -> Connection Pooling
# Use the "Transaction" mode URL (port 6543) for connection pooling
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Optional: pool sizing
DB_POOL_MIN=5
DB_POOL_MAX=20
